import { ComboBox } from "std-widgets.slint";

// ═══════════════════════════════════════════════════════════════
//  FASTTRACK — "Mission Control" Design System
//  Deep matte blacks · warm amber command accents · layered depth
//  Now with integrated icon assets throughout the interface
// ═══════════════════════════════════════════════════════════════

component Badge inherits Rectangle {
    in property <string> text;
    in property <color> tone: #E8A43A;

    height: 22px;
    border-radius: 4px;
    background: tone.transparentize(0.85);
    border-width: 1px;
    border-color: tone.transparentize(0.30);
    drop-shadow-blur: 8px;
    drop-shadow-color: tone.transparentize(0.80);

    // Inner highlight line
    Rectangle {
        x: 1px;
        y: 1px;
        width: parent.width - 2px;
        height: 1px;
        background: tone.transparentize(0.70);
        border-radius: 2px;
    }

    Text {
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: tone.brighter(0.45);
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 1.4px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component SectionCard inherits Rectangle {
    in property <string> title;
    in property <string> subtitle: "";
    in property <color> accent: #E8A43A;

    border-radius: 11px;
    background: #0E0E14;
    border-width: 1px;
    border-color: #1A1A26;
    clip: true;
    drop-shadow-blur: 28px;
    drop-shadow-color: #00000070;
    drop-shadow-offset-y: 6px;

    // Deep layered background gradient
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(170deg, #161620 0%, #0E0E14 40%, #0B0B10 100%);
    }

    // Subtle top edge highlight for depth
    Rectangle {
        x: 1px; y: 1px;
        width: parent.width - 2px;
        height: 1px;
        background: @linear-gradient(90deg, #ffffff08, #ffffff14, #ffffff08);
    }

    // Left accent bar — thicker, more dramatic gradient
    Rectangle {
        x: 0; y: 0;
        width: 3px;
        height: parent.height;
        background: @linear-gradient(180deg, root.accent.brighter(0.2), root.accent 50%, root.accent.transparentize(0.8) 100%);
    }

    // Accent glow bleed onto card surface
    Rectangle {
        x: 0; y: 0;
        width: 60px;
        height: parent.height;
        background: @linear-gradient(90deg, root.accent.transparentize(0.92), #00000000);
    }

    // Bottom inner shadow for depth
    Rectangle {
        x: 0;
        y: parent.height - 20px;
        width: parent.width;
        height: 20px;
        background: @linear-gradient(180deg, #00000000, #0000000A);
    }

    Text {
        x: 16px;
        y: 8px;
        text: root.title;
        color: #F0F0F8;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.4px;
        visible: root.title != "";
    }

    Text {
        x: 16px;
        y: 23px;
        text: root.subtitle;
        color: #525268;
        font-size: 9px;
        letter-spacing: 0.2px;
        visible: root.subtitle != "";
    }
}

// ─── Icon + text action button ───
component IconButton inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <color> icon-color: primary ? #0C0C10 : danger ? #FFD0D8 : #C8C8DC;
    callback clicked();

    height: 28px;
    border-radius: 14px;
    background: danger
        ? (tap.pressed ? #7A1828 : tap.has-hover ? #C83848 : #A02838)
        : primary
            ? (tap.pressed ? #C88A28 : tap.has-hover ? #F0B840 : #E8A43A)
            : (tap.pressed ? #18182A : tap.has-hover ? #2A2A40 : #1E1E30);
    border-width: 1px;
    border-color: danger
        ? (tap.has-hover ? #F06878C0 : #D0506880)
        : primary
            ? (tap.has-hover ? #FFCC70C0 : #F0C06880)
            : (tap.has-hover ? #404060 : #2A2A44);

    drop-shadow-blur: tap.has-hover
        ? (primary ? 18px : danger ? 14px : 8px)
        : (primary ? 10px : 0px);
    drop-shadow-color: danger
        ? (tap.has-hover ? #E0405040 : #E0405018)
        : primary
            ? (tap.has-hover ? #E8A43A50 : #E8A43A28)
            : (tap.has-hover ? #ffffff08 : #00000000);

    animate background { duration: 100ms; easing: ease-out; }
    animate drop-shadow-blur { duration: 180ms; easing: ease-out; }
    animate border-color { duration: 140ms; easing: ease-out; }

    // Top highlight for dimensionality
    Rectangle {
        x: 4px; y: 1px;
        width: parent.width - 8px;
        height: 1px;
        border-radius: 1px;
        background: danger
            ? #ffffff18
            : primary ? #ffffff20 : #ffffff0A;
    }

    Rectangle {
        width: icon_mark.width + 6px + label_text.preferred-width;
        height: parent.height;
        x: (parent.width - self.width) / 2;
        y: 0;
        background: #00000000;

        icon_mark := Image {
            width: 15px;
            height: 15px;
            x: 0;
            y: (parent.height - self.height) / 2;
            source: root.icon;
            colorize: root.icon-color;
            image-fit: contain;
        }

        label_text := Text {
            x: icon_mark.width + 6px;
            height: parent.height;
            text: root.label;
            color: primary ? #0C0C10 : danger ? #FFD0D8 : #C8C8DC;
            font-size: 10px;
            font-weight: primary ? 800 : 700;
            letter-spacing: 0.4px;
            vertical-alignment: center;
        }
    }

    tap := TouchArea {
        clicked => { root.clicked(); }
    }
}

component Field inherits Rectangle {
    in-out property <string> value;
    in property <string> placeholder;
    callback edited(string);

    height: 28px;
    border-radius: 6px;
    background: #080810;
    border-width: 1px;
    border-color: editor.has-focus ? #E8A43A : #1A1A28;

    drop-shadow-blur: editor.has-focus ? 12px : 0px;
    drop-shadow-color: editor.has-focus ? #E8A43A28 : #00000000;

    animate border-color { duration: 160ms; easing: ease-out; }
    animate drop-shadow-blur { duration: 200ms; easing: ease-out; }

    // Inner top shadow for inset look
    Rectangle {
        x: 1px; y: 1px;
        width: parent.width - 2px;
        height: 7px;
        border-radius: 5px;
        background: @linear-gradient(180deg, #00000028, #00000000);
    }

    // Focus indicator glow line at bottom
    Rectangle {
        x: 8px;
        y: parent.height - 1px;
        width: parent.width - 16px;
        height: 1px;
        border-radius: 1px;
        background: editor.has-focus ? #E8A43A60 : #00000000;
        animate background { duration: 200ms; easing: ease-out; }
    }

    editor := TextInput {
        x: 11px;
        width: parent.width - 22px;
        height: parent.height;
        text <=> root.value;
        color: #E8E8F4;
        font-size: 10px;
        vertical-alignment: center;
        selection-background-color: #E8A43A50;
        edited => { root.edited(editor.text); }
    }

    Text {
        x: 11px;
        width: parent.width - 22px;
        height: parent.height;
        text: root.placeholder;
        color: #3A3A52;
        font-size: 10px;
        vertical-alignment: center;
        visible: root.value == "" && !editor.has-focus;
    }
}

// ─── Folder browse button with icon ───
component PathButton inherits Rectangle {
    callback clicked();

    width: 32px;
    height: 28px;
    border-radius: 14px;
    background: tap.pressed ? #18182A : tap.has-hover ? #2A2A40 : #1E1E30;
    border-width: 1px;
    border-color: tap.has-hover ? #404060 : #2A2A44;

    animate background { duration: 100ms; easing: ease-out; }
    animate border-color { duration: 140ms; easing: ease-out; }

    Image {
        width: 15px;
        height: 15px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: @image-url("../assets/icon_folder_ui.png");
        colorize: #C8C8DC;
        image-fit: contain;
    }

    tap := TouchArea {
        clicked => { root.clicked(); }
    }
}

component CheckToggle inherits Rectangle {
    in-out property <bool> checked: false;
    in property <string> label;
    callback toggled(bool);

    height: 28px;
    border-radius: 8px;
    background: tap.pressed ? #171722 : tap.has-hover ? #202032 : #141420;
    border-width: 1px;
    border-color: checked ? #34D39970 : tap.has-hover ? #34344E : #242438;

    animate background { duration: 100ms; easing: ease-out; }
    animate border-color { duration: 140ms; easing: ease-out; }

    Rectangle {
        x: 8px;
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        border-radius: 4px;
        background: root.checked ? #34D399 : #0B0B12;
        border-width: 1px;
        border-color: root.checked ? #5EF0BC : #303048;

        Text {
            width: parent.width;
            height: parent.height;
            text: root.checked ? "✓" : "";
            color: #08110E;
            font-size: 10px;
            font-weight: 900;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: 29px;
        width: parent.width - 37px;
        height: parent.height;
        text: root.label;
        color: #B8B8D0;
        font-size: 9px;
        font-weight: 700;
        vertical-alignment: center;
        wrap: word-wrap;
    }

    tap := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

component FieldLabel inherits Text {
    in property <string> text-value;
    text: root.text-value;
    color: #7A7A94;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.3px;
    vertical-alignment: center;
}

component ProgressStrip inherits Rectangle {
    in property <float> value: 0.0;
    in property <string> label;
    in property <color> tone: #4CC9F0;

    height: 24px;
    background: #00000000;

    VerticalLayout {
        spacing: 2px;

        HorizontalLayout {
            Text {
                text: root.label;
                color: #58586E;
                font-size: 9px;
                font-weight: 800;
                letter-spacing: 1.2px;
            }

            Text {
                text: Math.round(clamp(root.value, 0, 1) * 100) + "%";
                color: clamp(root.value, 0, 1) > 0 ? root.tone.brighter(0.2) : #58586E;
                font-size: 9px;
                font-weight: 800;
                horizontal-alignment: right;
            }
        }

        Rectangle {
            height: 6px;
            border-radius: 3px;
            background: #080810;
            border-width: 1px;
            border-color: #1A1A28;
            clip: true;

            // Inner shadow for track depth
            Rectangle {
                x: 0; y: 0;
                width: parent.width;
                height: 3px;
                background: @linear-gradient(180deg, #00000040, #00000000);
            }

            // Glow halo behind fill bar
            Rectangle {
                width: parent.width * clamp(root.value, 0, 1);
                height: parent.height + 4px;
                y: -2px;
                border-radius: parent.border-radius;
                background: root.tone.transparentize(0.75);
                drop-shadow-blur: 10px;
                drop-shadow-color: root.tone.transparentize(0.50);
                animate width { duration: 200ms; easing: ease-out; }
            }

            // Main fill bar with tricolor gradient
            Rectangle {
                width: parent.width * clamp(root.value, 0, 1);
                height: parent.height;
                border-radius: parent.border-radius;
                background: @linear-gradient(90deg, root.tone.darker(0.35), root.tone 60%, root.tone.brighter(0.25));
                animate width { duration: 200ms; easing: ease-out; }

                // Specular highlight on fill bar
                Rectangle {
                    x: 0; y: 0;
                    width: parent.width;
                    height: 3px;
                    border-radius: 2px;
                    background: @linear-gradient(90deg, #ffffff00, #ffffff18, #ffffff00);
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    width: 670px;
    height: 645px;
    title: "FastTrack";
    background: #08080C;
    default-font-family: "Segoe UI";

    in-out property <string> status_text: "Ready";
    in-out property <string> drives_text: "";
    in-out property <string> source_drive: "";
    in-out property <string> client_name: "";
    in-out property <string> event_name: "";
    in-out property <string> camera_label: "";
    in-out property <string> base_path: "";
    in-out property <bool> skip_already_copied: false;
    in-out property <string> report_text: "";
    in-out property <[string]> event_menu: [];
    in-out property <int> event_menu_index: -1;
    in-out property <float> progress_percent: 0.0;
    in-out property <float> verify_percent: 0.0;
    in-out property <string> progress_label: "";

    callback refresh_cards();
    callback scan_card();
    callback start_ingest();
    callback cancel_ingest();
    callback show_history();
    callback suggest_client();
    callback select_source_path();
    callback select_base_path();
    callback source_drive_edited(string);
    callback client_name_edited(string);
    callback event_name_edited(string);

    // ═══ Multi-layer background ═══
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(155deg, #0D0D14, #08080C 45%, #0A0A10 80%, #0C0C12);

        // Warm command glow — top left (stronger)
        Rectangle {
            x: -80px; y: -50px;
            width: 340px; height: 280px;
            border-radius: 170px;
            background: #E8A43A06;
            drop-shadow-blur: 100px;
            drop-shadow-color: #E8A43A18;
        }

        // Cool operational glow — bottom right
        Rectangle {
            x: parent.width - 180px;
            y: parent.height - 140px;
            width: 280px; height: 220px;
            border-radius: 140px;
            background: #4CC9F004;
            drop-shadow-blur: 80px;
            drop-shadow-color: #4CC9F012;
        }

        // Emerald status glow — center-right
        Rectangle {
            x: parent.width - 250px;
            y: parent.height / 2 + 40px;
            width: 160px; height: 100px;
            border-radius: 50px;
            background: #34D39903;
            drop-shadow-blur: 60px;
            drop-shadow-color: #34D3990A;
        }

        // Warm center diffusion
        Rectangle {
            x: parent.width / 2 - 120px;
            y: 120px;
            width: 240px; height: 160px;
            border-radius: 80px;
            background: #E8A43A02;
            drop-shadow-blur: 60px;
            drop-shadow-color: #E8A43A06;
        }
    }

    VerticalLayout {
        padding: 6px;
        spacing: 5px;

        HorizontalLayout {
            padding-left: 3px;
            padding-right: 3px;
            padding-top: 0px;
            padding-bottom: 0px;
            spacing: 7px;
            alignment: start;

            Rectangle {
                width: 30px;
                height: 30px;
                border-radius: 8px;
                clip: true;
                background: #0A0A12;
                border-width: 1px;
                border-color: #E8A43A28;
                drop-shadow-blur: 10px;
                drop-shadow-color: #E8A43A18;

                Image {
                    x: 2px; y: 2px;
                    width: parent.width - 4px;
                    height: parent.height - 4px;
                    source: @image-url("../assets/app_icon.png");
                    image-fit: contain;
                }
            }

            VerticalLayout {
                spacing: 1px;
                alignment: center;

                Text {
                    text: "FastTrack";
                    color: #FFFFFF;
                    font-size: 15px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }

                Text {
                    text: "Reliable media ingest for client delivery";
                    color: #4A4A60;
                    font-size: 8px;
                    letter-spacing: 0.2px;
                }
            }
        }

        // ═══════════════════════════
        //  DETECTED CARDS — Scanner
        // ═══════════════════════════
        SectionCard {
            height: 102px;
            title: "Detected Cards";
            subtitle: "Refresh devices, inspect sources, and start ingest";
            accent: #4CC9F0;

            Badge {
                x: parent.width - 72px;
                y: 8px;
                width: 54px;
                text: "AUTO";
                tone: #4CC9F0;
            }

            VerticalLayout {
                x: 0;
                y: 38px;
                width: parent.width;
                height: parent.height - 38px;
                padding-left: 13px;
                padding-right: 13px;
                padding-bottom: 8px;
                spacing: 5px;

                HorizontalLayout {
                    spacing: 6px;

                    IconButton {
                        label: "Refresh";
                        icon: @image-url("../assets/icon_refresh_ui.png");
                        clicked => { refresh_cards(); }
                    }
                    IconButton {
                        label: "Scan";
                        icon: @image-url("../assets/icon_scan_ui.png");
                        clicked => { scan_card(); }
                    }
                    IconButton {
                        label: "Ingest";
                        icon: @image-url("../assets/icon_ingest_ui.png");
                        primary: true;
                        clicked => { start_ingest(); }
                    }
                    IconButton {
                        label: "Stop";
                        icon: @image-url("../assets/icon_stop_ui.png");
                        danger: true;
                        clicked => { cancel_ingest(); }
                    }
                    IconButton {
                        label: "History";
                        icon: @image-url("../assets/icon_history_ui.png");
                        clicked => { show_history(); }
                    }
                }

                Rectangle {
                    border-radius: 8px;
                    background: #080810;
                    border-width: 1px;
                    border-color: #1A1A28;
                    clip: true;

                    // Inner top shadow
                    Rectangle {
                        x: 0; y: 0;
                        width: parent.width;
                        height: 6px;
                        background: @linear-gradient(180deg, #00000020, #00000000);
                    }

                    Flickable {
                        viewport-height: max(self.height, drive-text.preferred-height + 18px);

                        drive-text := Text {
                            x: 12px;
                            y: 8px;
                            width: parent.width - 24px;
                            text: drives-text == "" ? "No cards detected. Insert media and run scan." : drives-text;
                            color: drives-text == "" ? #3A3A52 : #B8B8D0;
                            font-size: 10px;
                            wrap: word-wrap;
                            font-family: "Consolas";
                        }
                    }
                }
            }
        }

        // ══════════════════════════
        //  SESSION SETUP — Config
        // ══════════════════════════
        SectionCard {
            height: 214px;
            title: "Session Setup";
            subtitle: "Define source, client, event, camera label, and destination";
            accent: #E8A43A;

            VerticalLayout {
                x: 0;
                y: 38px;
                width: parent.width;
                height: parent.height - 38px;
                padding-left: 13px;
                padding-right: 13px;
                padding-bottom: 8px;
                spacing: 5px;

                HorizontalLayout {
                    spacing: 8px;
                    FieldLabel { width: 54px; height: 28px; text-value: "Source"; }
                    Field {
                        value <=> source_drive;
                        placeholder: "E:\\ or /Volumes/MEDIA";
                        edited(value) => { source_drive_edited(value); }
                    }
                    PathButton { clicked => { select_source_path(); } }
                }

                HorizontalLayout {
                    spacing: 8px;
                    FieldLabel { width: 54px; height: 28px; text-value: "Client"; }
                    Field {
                        value <=> client_name;
                        placeholder: "Client name";
                        edited(value) => { client_name_edited(value); }
                    }
                    IconButton {
                        width: 108px;
                        label: "Search";
                        icon: @image-url("../assets/icon_search_ui.png");
                        clicked => { suggest_client(); }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    FieldLabel { width: 54px; height: 28px; text-value: "Event"; }
                    Field {
                        value <=> event_name;
                        placeholder: "Wedding / Session";
                        edited(value) => { event_name_edited(value); }
                    }
                    ComboBox {
                        width: 150px;
                        height: 28px;
                        model: root.event_menu;
                        current-index <=> root.event_menu_index;
                        selected(value) => {
                            root.event_name = value;
                            event_name_edited(value);
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    FieldLabel { width: 54px; height: 28px; text-value: "Camera"; }
                    Field {
                        value <=> camera_label;
                        placeholder: "Optional camera label";
                    }
                    CheckToggle {
                        width: 176px;
                        checked <=> skip_already_copied;
                        label: "Skip already copied files";
                    }
                }

                HorizontalLayout {
                    spacing: 8px;
                    FieldLabel { width: 54px; height: 28px; text-value: "Dest"; }
                    Field {
                        value <=> base_path;
                        placeholder: "D:\\Projects";
                    }
                    PathButton { clicked => { select_base_path(); } }
                }
            }
        }

        // ═══════════════════════════
        //  LIVE STATUS — Monitor
        // ═══════════════════════════
        SectionCard {
            height: 272px;
            title: "Live Status";
            subtitle: "Copy, verify, and review ingest output";
            accent: #34D399;

            Badge {
                x: parent.width - 72px;
                y: 8px;
                width: 54px;
                text: "LIVE";
                tone: #34D399;
            }

            VerticalLayout {
                x: 0;
                y: 38px;
                width: parent.width;
                height: parent.height - 38px;
                padding-left: 13px;
                padding-right: 13px;
                padding-bottom: 8px;
                spacing: 5px;

                Rectangle {
                    height: 64px;
                    border-radius: 8px;
                    background: #080810;
                    border-width: 1px;
                    border-color: #1A1A28;
                    clip: true;

                    // Inner top shadow
                    Rectangle {
                        x: 0; y: 0;
                        width: parent.width;
                        height: 6px;
                        background: @linear-gradient(180deg, #00000020, #00000000);
                    }

                    // Left green indicator line when active
                    Rectangle {
                        x: 0; y: 4px;
                        width: 2px;
                        height: parent.height - 8px;
                        border-radius: 1px;
                        background: progress_percent > 0 ? #34D39980 : #34D39920;
                    }

                    Text {
                        x: 12px;
                        y: 10px;
                        width: parent.width - 24px;
                        height: 38px;
                        text: status_text;
                        color: #EEEEF6;
                        font-size: 13px;
                        font-weight: 700;
                        wrap: word-wrap;
                        overflow: clip;
                        vertical-alignment: center;
                        letter-spacing: 0.1px;
                    }

                    Rectangle {
                        x: 12px;
                        y: 44px;
                        width: parent.width - 24px;
                        height: 1px;
                        background: #1A1A28;
                    }

                    Text {
                        x: 12px;
                        y: 48px;
                        width: parent.width - 24px;
                        height: 12px;
                        text: progress_label == "" ? "Waiting for the next ingest action." : progress_label;
                        color: #5C5C74;
                        font-size: 9px;
                        letter-spacing: 0.1px;
                        overflow: clip;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    spacing: 12px;
                    ProgressStrip { value: progress_percent; label: "COPY"; tone: #4CC9F0; }
                    ProgressStrip { value: verify_percent; label: "VERIFY"; tone: #34D399; }
                }

                HorizontalLayout {
                    spacing: 0;
                    alignment: start;

                    Text {
                        text: "INGEST LOG";
                        color: #484860;
                        font-size: 9px;
                        font-weight: 800;
                        letter-spacing: 1.4px;
                    }
                }

                Rectangle {
                    height: 100px;
                    border-radius: 8px;
                    background: #080810;
                    border-width: 1px;
                    border-color: #1A1A28;
                    clip: true;

                    // Inner top shadow
                    Rectangle {
                        x: 0; y: 0;
                        width: parent.width;
                        height: 6px;
                        background: @linear-gradient(180deg, #00000020, #00000000);
                    }

                    Flickable {
                        width: parent.width;
                        height: parent.height;
                        viewport-width: self.width;
                        viewport-height: max(self.height, report-block.preferred-height + 20px);

                        report-block := Text {
                            x: 12px;
                            y: 8px;
                            width: parent.width - 24px;
                            text: report_text == "" ? "System idle. Waiting for ingest..." : report_text;
                            color: report_text == "" ? #3A3A52 : #A8A8C4;
                            font-size: 10px;
                            wrap: word-wrap;
                            font-family: "Consolas";
                        }
                    }
                }
            }
        }
    }
}
